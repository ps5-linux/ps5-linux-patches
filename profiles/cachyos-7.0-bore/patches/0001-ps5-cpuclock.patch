+static u32 pcirc_smn_read(u32 reg)
+{
+	u32 val = 0;
+	if (amd_smn_read(0, reg, &val)) {
+		panic("amd_smn_read failed");
+	}
+	return val;
+}
+
+static void pcirc_smn_write(u32 reg, u32 val)
+{
+	if (amd_smn_write(0, reg, val)) {
+		panic("amd_smn_write failed");
+	}
+}
+
+static int mp1fw_waitmsg(u32 reg, u8 msgid)
+{
+        int timeout = 0;
+
+        while (!pcirc_smn_read(reg)) {
+                udelay(10);
+                if (++timeout == 200000) {
+                        return 1;
+                }
+        }
+
+        if (timeout >= 10000) {
+                pr_err("[MP1] wait %d msec (msgid=0x%X)\n", timeout / 100, msgid);
+                return 0;
+        }
+
+        return 0;
+}
+
+static int __mp1fw_sendmsg(struct mp1_msg *msg, u8 msgid)
+{
+	if (mp1fw_waitmsg(MP1_C2PMSG_90, msgid)) {
+		pr_err("[MP1ERROR] : %s: Error : busy msgid=0x%X, arg=0x%08X\n", __func__, msgid, msg->arg);
+		return -EBUSY;
+	}
+
+	pcirc_smn_write(MP1_C2PMSG_90, 0);
+	pcirc_smn_write(MP1_C2PMSG_82, msg->arg);
+	if (msg->extra == 1)
+		pcirc_smn_write(MP1_C2PMSG_81, msg->extra_arg);
+	pcirc_smn_write(MP1_C2PMSG_66, msgid);
+
+	if (mp1fw_waitmsg(MP1_C2PMSG_90, msgid)) {
+		pr_err("[MP1ERROR] : %s: Error : retry over msgid=0x%X, arg=0x%08X\n", __func__, msgid, msg->arg);
+		return -EBUSY;
+	}
+
+	u32 resp = pcirc_smn_read(MP1_C2PMSG_90);
+	u32 resp_val = pcirc_smn_read(MP1_C2PMSG_82);
+	if (resp != 1) {
+		pr_err("[MP1ERROR] : %s: invalid response msgid=0x%X, resp=0x%08X\n", __func__, msgid, resp);
+		return -EINVAL;
+	}
+
+	msg->resp = resp;
+	msg->resp_val = resp_val;
+
+	return 0;
+}
+
+static int mp1fw_sendmsg(struct mp1_msg *msg, u8 msgid)
+{
+	int ret;
+
+	mutex_lock(&mp1_mbox_mutex);
+	ret = __mp1fw_sendmsg(msg, msgid);
+	mutex_unlock(&mp1_mbox_mutex);
+
+	return ret;
+}
+
+static int __mp1fw_test_sendmsg(struct mp1_msg *msg, uint8_t msgid)
+{
+	if (mp1fw_waitmsg(MP1_C2PMSG_96, msgid)) {
+		printk("[MP1ERROR] : %s: Error : busy msgid=0x%X, arg=0x%08X\n", __func__, msgid, msg->arg);
+		return -EBUSY;
+	}
+	pcirc_smn_write(MP1_C2PMSG_96, 0);
+	pcirc_smn_write(MP1_C2PMSG_98, msg->arg);
+	pcirc_smn_write(MP1_C2PMSG_72, msgid);
+	if (mp1fw_waitmsg(MP1_C2PMSG_96, msgid)) {
+		printk("[MP1ERROR] : %s: retry over msgid=0x%X, arg=0x%08X\n", __func__, msgid, msg->arg);
+		return -EBUSY;
+	}
+	u32 resp = pcirc_smn_read(MP1_C2PMSG_96);
+	u32 resp_val = pcirc_smn_read(MP1_C2PMSG_98);
+	if ((msgid != 0x75 && resp != 1) || (msgid == 0x75 && resp != 1 && resp != 0xf8)) {
+		printk("[MP1ERROR] : %s: invalid response msgid=0x%X, resp=0x%08X\n", __func__, msgid, resp);
+		return -EINVAL;
+	}
+
+	msg->resp = resp;
+	msg->resp_val = resp_val;
+
+	return 0;
+}
+
+static int mp1fw_test_sendmsg(struct mp1_msg *msg, uint8_t msgid)
+{
+	int ret;
+
+	mutex_lock(&mp1_mbox_mutex);
+	ret = __mp1fw_test_sendmsg(msg, msgid);
+	mutex_unlock(&mp1_mbox_mutex);
+
+	return ret;
+}
+
+int ps5_mp1_mailbox_xfer(enum ps5_mp1_queue queue, u8 msgid, u32 arg,
+			  u32 *resp_val)
+{
+	struct mp1_msg msg = {
+		.arg = arg,
+	};
+	int ret;
+
+	switch (queue) {
+	case PS5_MP1_QUEUE0:
+		ret = mp1fw_sendmsg(&msg, msgid);
+		break;
+	case PS5_MP1_QUEUE_TEST:
+		ret = mp1fw_test_sendmsg(&msg, msgid);
+		break;
+	default:
+		return -EINVAL;
+	}
+
+	if (ret)
+		return ret;
+
+	if (resp_val)
+		*resp_val = msg.resp_val;
+
+	return 0;
+}
+EXPORT_SYMBOL_GPL(ps5_mp1_mailbox_xfer);
+
+static int mp1_set_wc_cpu(int mode)
+{
+	struct mp1_msg msg = {};
+	msg.arg = mode;
+	return mp1fw_test_sendmsg(&msg, 0x9b);
+}
+
+static int mp1_get_wc_cpu(int *mode)
+{
+	struct mp1_msg msg = {};
+	int ret;
+	ret = mp1fw_test_sendmsg(&msg, 0x9c);
+	*mode = msg.resp_val;
+	return ret;
+}
+
+static int mp1_configure_s3_pwr_off_reg_addr_high(u64 addr)
+{
+	struct mp1_msg msg = {};
+	msg.arg = addr >> 32;
+	return mp1fw_sendmsg(&msg, PPSMC_MSG_ConfigureS3PwrOffRegisterAddressHigh);
+}
+
+static int mp1_configure_s3_pwr_off_reg_addr_low(u64 addr)
+{
+	struct mp1_msg msg = {};
+	msg.arg = addr & 0xffffffff;
+	return mp1fw_sendmsg(&msg, PPSMC_MSG_ConfigureS3PwrOffRegisterAddressLow);
+}
+
+void mp1_set_pm1_addr(u64 addr)
+{
+	mp1_configure_s3_pwr_off_reg_addr_high(addr);
+	mp1_configure_s3_pwr_off_reg_addr_low(addr);
+}
+EXPORT_SYMBOL(mp1_set_pm1_addr);
+
+int mp1_set_sleep_entry(void)
+{
+	struct mp1_msg msg = {};
+	msg.arg = 3; /* S3 */
+	return mp1fw_sendmsg(&msg, PPSMC_MSG_SleepEntry);
+}
+EXPORT_SYMBOL(mp1_set_sleep_entry);
+
+static int mp1_universal_mode_enter(u32 *params)
+{
+	struct mp1_msg msg = {};
+	int ret;
+
+	mutex_lock(&mp1_mbox_mutex);
+	pcirc_smn_write(MP1_C2PMSG_56, params[1]);
+	pcirc_smn_write(MP1_C2PMSG_57, params[2]);
+	pcirc_smn_write(MP1_C2PMSG_58, params[3]);
+	pcirc_smn_write(MP1_C2PMSG_59, params[4]);
+
+	msg.arg = params[0];
+	ret = __mp1fw_sendmsg(&msg, PPSMC_MSG_UniversalModeEntry);
+	mutex_unlock(&mp1_mbox_mutex);
+
+	return ret;
+}
+
+static int mp1_universal_mode_exit(void)
+{
+	struct mp1_msg msg = {};
+	return mp1fw_sendmsg(&msg, PPSMC_MSG_UniversalModeExit);
+}
+
+static int mp1_bapm_set_gfx_cacw(int index, int weight)
+{
+	struct mp1_msg msg = {};
+	msg.arg = index | 0x20000;
+	msg.extra_arg = weight;
+	msg.extra = 1;
+	return mp1fw_sendmsg(&msg, PPSMC_MSG_GfxCacWeightOperation);
+}
+
+static int mp1_bapm_set_l3_cacw(int index, int weight)
+{
+	struct mp1_msg msg = {};
+	msg.arg = index | 0x20000;
+	msg.extra_arg = weight;
+	msg.extra = 1;
+	return mp1fw_sendmsg(&msg, PPSMC_MSG_L3CacWeightOperation);
+}
+
+static int mp1_bapm_write_param(int index, int param)
+{
+	struct mp1_msg msg = {};
+	msg.arg = index;
+	msg.extra_arg = param;
+	msg.extra = 1;
+	return mp1fw_sendmsg(&msg, 0x33);
+}
+
+static void update_bapm_weights_smp(void *info)
+{
+	u64 msr_dpm_cfg;
+	int i;
+
+	rdmsrq(MSR_DPM_CFG, msr_dpm_cfg);
+	wrmsrq(MSR_DPM_CFG, msr_dpm_cfg & ~MSR_ACCESS_DIS);
+
+	for (i = 0; i < 21; i++) {
+		wrmsrq(MSR_DPM_WAC_ACC_INDEX, i);
+		wrmsrq(MSR_DPM_WAC_DATA, bapm_param_set_2.dpm_wac[i]);
+	}
+
+	wrmsrq(MSR_DPM_CFG, msr_dpm_cfg);
+}
+
+static void mp1_set_bapm_param_set_all(void)
+{
+	int i;
+
+	on_each_cpu(update_bapm_weights_smp, NULL, 1);
+
+	for (i = 0; i < 80; i++) {
+		mp1_bapm_set_l3_cacw(i, bapm_param_set_2.l3_cacw[i]);
+	}
+
+	for (i = 0; i < bapm_param_set_2.gfx_cacw_len; i++) {
+		mp1_bapm_set_gfx_cacw(i, bapm_param_set_2.gfx_cacw[i]);
+	}
+
+	for (i = 0; i < 176; i++) {
+		if (bapm_param_set_2.bapm_param[i][0])
+			mp1_bapm_write_param(i, bapm_param_set_2.bapm_param[i][1]);
+	}
+}
+
+static long mp1_ioctl(struct file *file, unsigned int cmd, unsigned long arg)
+{
+	switch (cmd) {
+	case MP1_BOOST_ENTER:
+	{
+		u32 params[5];
+		params[0] = 0x0;
+		params[1] = 0x449cd;
+		params[2] = (GPU_MHZ_MIN << 16) | CPU_MHZ_MIN;
+		params[3] = (GPU_MHZ_MAX << 16) | CPU_MHZ_MAX;
+		params[4] = 0x25c6a3c8;
+		return mp1_universal_mode_enter(params);
+	}
+
+	case MP1_BOOST_EXIT:
+		return mp1_universal_mode_exit();
+
+	default:
+		return -ENOTTY;
+	}
+}
+
+static const struct file_operations mp1_fops = {
+	.owner = THIS_MODULE,
+	.unlocked_ioctl = mp1_ioctl,
+};
+
+static struct miscdevice mp1_misc_device = {
+	.minor = MISC_DYNAMIC_MINOR,
+	.name = "mp1",
+	.fops = &mp1_fops,
+};
+
+static int __init mp1_init(void)
+{
+	int ret;
+	int mode = 0;
+
+	mp1_universal_mode_exit();
+
+	pr_info("Set BAPM params\n");
+	mp1_get_wc_cpu(&mode);
+	if (mode != 1) {
+		mp1_set_wc_cpu(1);
+	}
+	mp1_set_bapm_param_set_all();
+
+	ret = misc_register(&mp1_misc_device);
+	if (ret)
+		return ret;
+
+	return 0;
+}
+
+static void __exit mp1_exit(void)
+{
+	misc_deregister(&mp1_misc_device);
+	mp1_universal_mode_exit();
+}
+
+module_init(mp1_init);
+module_exit(mp1_exit);
+
+MODULE_AUTHOR("Andy Nguyen");
+MODULE_DESCRIPTION("PlayStation 5 MP1 SMU driver");
+MODULE_LICENSE("GPL");
diff --git a/drivers/ps5/power.c b/drivers/ps5/power.c
new file mode 100644
index 000000000..0608f570c
--- /dev/null
+++ b/drivers/ps5/power.c
@@ -0,0 +1,421 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * PlayStation 5 APU power controls.
+ *
+ * CPU P-states are exposed through cpufreq. PS5-specific GPU GFXCLK, data
+ * fabric P-state, and voltage telemetry are exposed as device attributes.
+ */
+
+#define pr_fmt(fmt) KBUILD_MODNAME ": " fmt
+
+#include <linux/cpufreq.h>
+#include <linux/device.h>
+#include <linux/delay.h>
+#include <linux/kernel.h>
+#include <linux/module.h>
+#include <linux/platform_device.h>
+#include <linux/ps5.h>
+#include <linux/slab.h>
+
+#define PS5_CPU_MASK_ALL		0xff
+#define PS5_CPU_DEFAULT_PSTATE		0
+#define PS5_GPU_DEFAULT_MHZ		2000
+#define PS5_GPU_MIN_MHZ			400
+#define PS5_GPU_MAX_MHZ			2380
+#define PS5_DF_DEFAULT_PSTATE		3
+#define PS5_DF_SAFE_MIN_PSTATE		2
+#define PS5_DF_MAX_PSTATE		3
+#define PS5_VERIFY_TRIES		2000
+#define PS5_VERIFY_SLEEP_US		1500
+
+#define PPSMC_MSG_REQUEST_CORE_PSTATE	0x0b
+#define PPSMC_MSG_QUERY_CORE_PSTATE	0x0c
+#define PPSMC_MSG_REQUEST_GFXCLK	0x0e
+#define PPSMC_MSG_QUERY_GFXCLK		0x0f
+#define PPSMC_MSG_REQUEST_DF_PSTATE	0x12
+#define PPSMC_MSG_QUERY_DF_PSTATE	0x13
+#define PPSMC_MSG_GET_CPU_VOLTAGE	0x36
+#define PPSMC_MSG_GET_GPU_VOLTAGE	0x37
+
+struct ps5_cpu_pstate {
+	unsigned int pstate;
+	unsigned int khz;
+};
+
+static const struct ps5_cpu_pstate ps5_cpu_pstates[] = {
+	{ 0, 3200000 },
+	{ 1, 2560000 },
+	{ 2, 2327000 },
+	{ 3, 1969000 },
+	{ 4, 1829000 },
+	{ 5, 1600000 },
+	{ 6, 1280000 },
+	{ 7,  800000 },
+};
+
+static struct cpufreq_frequency_table ps5_cpufreq_table[] = {
+	{ .driver_data = 0, .frequency = 3200000 },
+	{ .driver_data = 1, .frequency = 2560000 },
+	{ .driver_data = 2, .frequency = 2327000 },
+	{ .driver_data = 3, .frequency = 1969000 },
+	{ .driver_data = 4, .frequency = 1829000 },
+	{ .driver_data = 5, .frequency = 1600000 },
+	{ .driver_data = 6, .frequency = 1280000 },
+	{ .driver_data = 7, .frequency =  800000 },
+	{ .frequency = CPUFREQ_TABLE_END },
+};
+
+static bool allow_unsafe_df;
+module_param(allow_unsafe_df, bool, 0644);
+MODULE_PARM_DESC(allow_unsafe_df, "allow df0/df1 writes despite known mailbox hang risk");
+
+static struct platform_device *ps5_power_pdev;
+
+static int ps5_mp1_xfer(enum ps5_mp1_queue queue, u8 msg, u32 arg, u32 *val)
+{
+	return ps5_mp1_mailbox_xfer(queue, msg, arg, val);
+}
+
+static int ps5_cpu_set_pstate(u32 mask, u32 pstate)
+{
+	u32 arg = (mask & 0xff) | ((pstate & 0x0f) << 16);
+
+	return ps5_mp1_xfer(PS5_MP1_QUEUE0, PPSMC_MSG_REQUEST_CORE_PSTATE,
+			    arg, NULL);
+}
+
+static int ps5_cpu_get_pstate(u32 cpu, u32 *pstate)
+{
+	return ps5_mp1_xfer(PS5_MP1_QUEUE0, PPSMC_MSG_QUERY_CORE_PSTATE,
+			    cpu & 0xff, pstate);
+}
+
+static unsigned int ps5_cpu_pstate_to_khz(u32 pstate)
+{
+	int i;
+
+	for (i = 0; i < ARRAY_SIZE(ps5_cpu_pstates); i++) {
+		if (ps5_cpu_pstates[i].pstate == pstate)
+			return ps5_cpu_pstates[i].khz;
+	}
+
+	return 0;
+}
+
+static int ps5_gpu_get_gfxclk(u32 *mhz)
+{
+	return ps5_mp1_xfer(PS5_MP1_QUEUE0, PPSMC_MSG_QUERY_GFXCLK, 0, mhz);
+}
+
+static int ps5_gpu_set_gfxclk(u32 mhz)
+{
+	return ps5_mp1_xfer(PS5_MP1_QUEUE0, PPSMC_MSG_REQUEST_GFXCLK, mhz,
+			    NULL);
+}
+
+static int ps5_df_get_pstate(u32 *pstate)
+{
+	return ps5_mp1_xfer(PS5_MP1_QUEUE0, PPSMC_MSG_QUERY_DF_PSTATE, 0,
+			    pstate);
+}
+
+static int ps5_df_set_pstate(u32 pstate)
+{
+	return ps5_mp1_xfer(PS5_MP1_QUEUE0, PPSMC_MSG_REQUEST_DF_PSTATE,
+			    pstate, NULL);
+}
+
+static int ps5_read_voltage(u8 msg, u32 *mv)
+{
+	return ps5_mp1_xfer(PS5_MP1_QUEUE_TEST, msg, 0, mv);
+}
+
+static int ps5_wait_u32(const char *name, int (*read)(u32 *), u32 target)
+{
+	u32 cur = 0;
+	int i, ret;
+
+	for (i = 0; i < PS5_VERIFY_TRIES; i++) {
+		ret = read(&cur);
+		if (ret)
+			return ret;
+		if (cur == target)
+			return 0;
+		usleep_range(PS5_VERIFY_SLEEP_US, PS5_VERIFY_SLEEP_US + 500);
+	}
+
+	pr_warn("%s verify timeout: target %u, last %u\n", name, target, cur);
+	return -ETIMEDOUT;
+}
+
+static int ps5_gpu_set_verified(u32 mhz)
+{
+	int ret;
+
+	ret = ps5_gpu_set_gfxclk(mhz);
+	if (ret)
+		return ret;
+
+	return ps5_wait_u32("gfxclk", ps5_gpu_get_gfxclk, mhz);
+}
+
+static int ps5_df_set_verified(u32 pstate)
+{
+	int ret;
+
+	ret = ps5_df_set_pstate(pstate);
+	if (ret)
+		return ret;
+
+	return ps5_wait_u32("df_pstate", ps5_df_get_pstate, pstate);
+}
+
+static int ps5_restore_defaults(void)
+{
+	int ret, first = 0;
+
+	ret = ps5_cpu_set_pstate(PS5_CPU_MASK_ALL, PS5_CPU_DEFAULT_PSTATE);
+	if (ret && !first)
+		first = ret;
+
+	ret = ps5_gpu_set_verified(PS5_GPU_DEFAULT_MHZ);
+	if (ret && !first)
+		first = ret;
+
+	ret = ps5_df_set_verified(PS5_DF_DEFAULT_PSTATE);
+	if (ret && !first)
+		first = ret;
+
+	return first;
+}
+
+static int ps5_cpufreq_init(struct cpufreq_policy *policy)
+{
+	cpumask_copy(policy->cpus, cpu_possible_mask);
+	policy->shared_type = CPUFREQ_SHARED_TYPE_ANY;
+	policy->freq_table = ps5_cpufreq_table;
+	policy->cpuinfo.transition_latency = CPUFREQ_DEFAULT_TRANSITION_LATENCY_NS;
+
+	cpufreq_generic_init(policy, ps5_cpufreq_table,
+			     CPUFREQ_DEFAULT_TRANSITION_LATENCY_NS);
+
+	return 0;
+}
+
+static int ps5_cpufreq_target_index(struct cpufreq_policy *policy,
+				    unsigned int index)
+{
+	if (index >= ARRAY_SIZE(ps5_cpufreq_table) - 1)
+		return -EINVAL;
+
+	return ps5_cpu_set_pstate(PS5_CPU_MASK_ALL,
+				  ps5_cpufreq_table[index].driver_data);
+}
+
+static unsigned int ps5_cpufreq_get(unsigned int cpu)
+{
+	u32 pstate;
+
+	if (ps5_cpu_get_pstate(cpu, &pstate))
+		return 0;
+
+	return ps5_cpu_pstate_to_khz(pstate);
+}
+
+static int ps5_cpufreq_suspend(struct cpufreq_policy *policy)
+{
+	return ps5_cpu_set_pstate(PS5_CPU_MASK_ALL, PS5_CPU_DEFAULT_PSTATE);
+}
+
+static struct cpufreq_driver ps5_cpufreq_driver = {
+	.verify		= cpufreq_generic_frequency_table_verify,
+	.target_index	= ps5_cpufreq_target_index,
+	.get		= ps5_cpufreq_get,
+	.init		= ps5_cpufreq_init,
+	.suspend	= ps5_cpufreq_suspend,
+	.name		= "ps5-cpufreq",
+};
+
+static ssize_t gpu_gfxclk_mhz_show(struct device *dev,
+				   struct device_attribute *attr, char *buf)
+{
+	u32 mhz;
+	int ret;
+
+	ret = ps5_gpu_get_gfxclk(&mhz);
+	if (ret)
+		return ret;
+
+	return sysfs_emit(buf, "%u\n", mhz);
+}
+
+static ssize_t gpu_gfxclk_mhz_store(struct device *dev,
+				    struct device_attribute *attr,
+				    const char *buf, size_t count)
+{
+	u32 mhz;
+	int ret;
+
+	ret = kstrtou32(buf, 0, &mhz);
+	if (ret)
+		return ret;
+
+	if (mhz < PS5_GPU_MIN_MHZ || mhz > PS5_GPU_MAX_MHZ)
+		return -ERANGE;
+
+	ret = ps5_gpu_set_verified(mhz);
+	if (ret)
+		return ret;
+
+	return count;
+}
+static DEVICE_ATTR_RW(gpu_gfxclk_mhz);
+
+static ssize_t df_pstate_show(struct device *dev,
+			      struct device_attribute *attr, char *buf)
+{
+	u32 pstate;
+	int ret;
+
+	ret = ps5_df_get_pstate(&pstate);
+	if (ret)
+		return ret;
+
+	return sysfs_emit(buf, "%u\n", pstate);
+}
+
+static ssize_t df_pstate_store(struct device *dev,
+			       struct device_attribute *attr,
+			       const char *buf, size_t count)
+{
+	u32 pstate;
+	int ret;
+
+	ret = kstrtou32(buf, 0, &pstate);
+	if (ret)
+		return ret;
+
+	if (pstate > PS5_DF_MAX_PSTATE)
+		return -ERANGE;
+	if (pstate < PS5_DF_SAFE_MIN_PSTATE && !allow_unsafe_df)
+		return -EPERM;
+
+	ret = ps5_df_set_verified(pstate);
+	if (ret)
+		return ret;
+
+	return count;
+}
+static DEVICE_ATTR_RW(df_pstate);
+
+static ssize_t cpu_voltage_millivolt_show(struct device *dev,
+					  struct device_attribute *attr,
+					  char *buf)
+{
+	u32 mv;
+	int ret;
+
+	ret = ps5_read_voltage(PPSMC_MSG_GET_CPU_VOLTAGE, &mv);
+	if (ret)
+		return ret;
+
+	return sysfs_emit(buf, "%u\n", mv);
+}
+static DEVICE_ATTR_RO(cpu_voltage_millivolt);
+
+static ssize_t gpu_voltage_millivolt_show(struct device *dev,
+					  struct device_attribute *attr,
+					  char *buf)
+{
+	u32 mv;
+	int ret;
+
+	ret = ps5_read_voltage(PPSMC_MSG_GET_GPU_VOLTAGE, &mv);
+	if (ret)
+		return ret;
+
+	return sysfs_emit(buf, "%u\n", mv);
+}
+static DEVICE_ATTR_RO(gpu_voltage_millivolt);
+
+static ssize_t restore_defaults_store(struct device *dev,
+				      struct device_attribute *attr,
+				      const char *buf, size_t count)
+{
+	bool restore;
+	int ret;
+
+	ret = kstrtobool(buf, &restore);
+	if (ret)
+		return ret;
+	if (!restore)
+		return -EINVAL;
+
+	ret = ps5_restore_defaults();
+	if (ret)
+		return ret;
+
+	return count;
+}
+static DEVICE_ATTR_WO(restore_defaults);
+
+static struct attribute *ps5_power_attrs[] = {
+	&dev_attr_gpu_gfxclk_mhz.attr,
+	&dev_attr_df_pstate.attr,
+	&dev_attr_cpu_voltage_millivolt.attr,
+	&dev_attr_gpu_voltage_millivolt.attr,
+	&dev_attr_restore_defaults.attr,
+	NULL,
+};
+
+static const struct attribute_group ps5_power_attr_group = {
+	.attrs = ps5_power_attrs,
+};
+
+static int __init ps5_power_init(void)
+{
+	int ret;
+
+	ret = cpufreq_register_driver(&ps5_cpufreq_driver);
+	if (ret)
+		return ret;
+
+	ps5_power_pdev = platform_device_register_simple("ps5-power", -1,
+							 NULL, 0);
+	if (IS_ERR(ps5_power_pdev)) {
+		ret = PTR_ERR(ps5_power_pdev);
+		goto err_unregister_cpufreq;
+	}
+
+	ret = sysfs_create_group(&ps5_power_pdev->dev.kobj,
+				 &ps5_power_attr_group);
+	if (ret)
+		goto err_unregister_device;
+
+	pr_info("registered PS5 power controls\n");
+	return 0;
+
+err_unregister_device:
+	platform_device_unregister(ps5_power_pdev);
+err_unregister_cpufreq:
+	cpufreq_unregister_driver(&ps5_cpufreq_driver);
+	return ret;
+}
+
+static void __exit ps5_power_exit(void)
+{
+	if (ps5_power_pdev) {
+		sysfs_remove_group(&ps5_power_pdev->dev.kobj,
+				   &ps5_power_attr_group);
+		platform_device_unregister(ps5_power_pdev);
+	}
+	ps5_restore_defaults();
+	cpufreq_unregister_driver(&ps5_cpufreq_driver);
+}
+
+module_init(ps5_power_init);
+module_exit(ps5_power_exit);
+
+MODULE_AUTHOR("PS5 Linux contributors");
+MODULE_DESCRIPTION("PlayStation 5 APU power control driver");
+MODULE_LICENSE("GPL");
diff --git a/include/linux/ps5.h b/include/linux/ps5.h
new file mode 100644
index 000000000..55fe4c544
--- /dev/null
+++ b/include/linux/ps5.h
@@ -0,0 +1,101 @@
+#ifndef _LINUX_PS5_H
+#define _LINUX_PS5_H
+
+#include <linux/types.h>
+#include <drm/drm_modes.h>
+
+#define ICC_MSG_MIN_SIZE	0x20
+#define ICC_MSG_MAX_SIZE 	0x7f0
+
+struct icc_msg {
+	u8 magic;
+	u8 service_id;
+	u16 msg_type;
+	u16 unk_04;
+	u16 id;
+	u16 length;
+	u16 checksum;
+	u8 data[];
+};
+
+enum icc_service_id {
+	ICC_SERVICE_ID_CONFIGURATION	= 0x01,
+	ICC_SERVICE_ID_GENERAL		= 0x02,
+	ICC_SERVICE_ID_NVS		= 0x03,
+	ICC_SERVICE_ID_POWER		= 0x04,
+	ICC_SERVICE_ID_DEVICE		= 0x05,
+	ICC_SERVICE_ID_UNKNOWN_07	= 0x07,
+	ICC_SERVICE_ID_BUTTON		= 0x08,
+	ICC_SERVICE_ID_INDICATOR	= 0x09,
+	ICC_SERVICE_ID_FAN		= 0x0a,
+	ICC_SERVICE_ID_THERMAL		= 0x0b,
+	ICC_SERVICE_ID_HDMI		= 0x10,
+	ICC_SERVICE_ID_USBC		= 0x12,
+	ICC_SERVICE_ID_UNKNOWN_13	= 0x13,
+	ICC_SERVICE_ID_CRASH_REPORT	= 0x14,
+	ICC_SERVICE_ID_BDDRIVE		= 0x15,
+	ICC_SERVICE_ID_UNKNOWN_8C	= 0x8c,
+	ICC_SERVICE_ID_UNKNOWN_8D	= 0x8d,
+	ICC_SERVICE_ID_SC_CONFIG	= 0x8e,
+	ICC_SERVICE_ID_FLOYD		= 0x9a,
+};
+
+bool spcie_is_initialized(void);
+
+u32 spcie_get_chip_id(void);
+u32 spcie_get_revision_id(void);
+u32 spcie_bar2_180000_read(u32 reg);
+void spcie_bar2_180000_write(u32 reg, u32 val);
+u32 spcie_pervasive0_4000_read(u32 reg);
+
+int icc_query(u8 *query, u8 *reply);
+
+void hdmiSystemResume(void);
+void sceHdmiInitVideoConfig(void);
+void sceHdmiSetVideoConfig(const struct drm_display_mode *mode);
+void sceHdmiSetAudioConfig(int channels);
+void sceHdmiDeviceSetVideoMute(int mute);
+void sceHdmiSetAudioMute(int mute);
+void sceHdmiOutputMode(void);
+int getHdmiConfiguration(void);
+bool isHdmiModeValid(const struct drm_display_mode *mode, int force_1080p);
+
+int icc_nvs_write(u32 partition, u16 offset, u16 length, const void *data);
+int icc_nvs_read(u32 partition, u16 offset, u16 length, void *data);
+
+int icc_usbc_set_pdcon_op_mode(u8 PortId, u8 OpMode);
+int icc_configuration_set_cpu_info_bit(u8 *bit);
+int icc_configuration_clear_cpu_info_bit(void);
+
